rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Avatares — somente o próprio usuário pode escrever o seu avatar, máx 5MB, somente imagens
    match /avatars/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && fileName == request.auth.uid + '.jpg'
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Banners do home — admin escreve via dashboard, todos leem (são exibidos no app)
    match /banners/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == 'X619NYBpp5OqXKTBomuFTISuQGY2'
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
