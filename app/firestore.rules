rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Configuração do app (leitura autenticada, escrita admin via dashboard) ─
    match /config/{doc} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Sessões (token de dispositivo único, isolado por usuário) ────────────
    match /sessions/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Perfis de usuário ────────────────────────────────────────────────────
    match /usuarios/{uid} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null && request.auth.uid == uid;

      // Atualização 1 — campos não-financeiros (perfil e sessão)
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['nome', 'avatarURL', 'codigoAfiliado', 'modo']);

      // Atualização 2 — referidoPor: pode ser definido uma única vez, nunca alterado
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['referidoPor'])
        && resource.data.get('referidoPor', null) == null
        && request.resource.data.referidoPor is string
        && request.resource.data.referidoPor.size() > 0
        && request.resource.data.referidoPor != uid;

      // Atualização 3 — acúmulo de pontos (carregamento + login diário)
      // Máximo 60 pts por chamada (10/min + 50 bônus = 60 no pior caso).
      // Inclui ultimoLogin para cobrir registrarLoginDiario().
      // atividadeDias é mapa diário (chave YYYYMMDD) usado pelo ranking semanal.
      // minutos só pode aumentar 1 por operação quando presente.
      //
      // SECURITY 2026-05-12: pontos increment exige pareamento com minutos OU
      // ultimoLogin no mesmo write. Sem isso, um cliente forjado podia
      // spammar `pontos = prev + 60` em loop sem deixar rastro em minutos
      // (todos os fluxos legítimos sempre incluem um dos dois).
      //
      // SECURITY 2026-05-12: ultimoMinutoMs adicionado ao hasOnly para suportar
      // próxima fase de throttle (cliente >= v1.2.41 escreve esse campo a cada
      // adicionarMinutoComBonus). Após adoção, ativar regra time-based abaixo.
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['pontos', 'minutos', 'ultimoLogin', 'atividadeDias', 'ultimoMinutoMs'])
        && request.resource.data.diff(resource.data).affectedKeys().hasAny(['pontos'])
        && request.resource.data.pontos > resource.data.pontos
        && request.resource.data.pontos <= resource.data.pontos + 60
        // Pontos só podem subir se houver write paralelo de minutos+1 OU ultimoLogin
        && request.resource.data.diff(resource.data).affectedKeys().hasAny(['minutos', 'ultimoLogin'])
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['minutos'])
            || request.resource.data.minutos == resource.data.minutos + 1)
        // Throttle opcional: quando ultimoMinutoMs está sendo escrito, deve ser
        // request.time e respeitar gap de 50s (defesa em profundidade).
        // Clientes antigos sem ultimoMinutoMs continuam funcionando.
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['ultimoMinutoMs'])
            || (request.resource.data.ultimoMinutoMs == request.time
                && (resource.data.get('ultimoMinutoMs', null) == null
                    || request.time >= resource.data.ultimoMinutoMs + duration.value(50, 's'))));

      // Atualização 4 — saque: pontos diminui, saques aumenta 1
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['pontos', 'saques'])
        && request.resource.data.pontos < resource.data.pontos
        && request.resource.data.pontos >= 0
        && request.resource.data.saques == resource.data.saques + 1;

      // NOTA: atualizações cross-user (comissões, crédito de indicação) são
      // exclusivamente feitas pelo SDK Admin nas Cloud Functions — sem regra necessária.
      // Campos server-only (bloqueados pelos hasOnly acima): indicacoesAtivas,
      // bonus5kGranted, bonus10kGranted, contadoComoAtivo — escritos apenas por
      // onReferreeBecameActive / backfillMilestones.js via Admin SDK.

      // Atualização 5 — heartbeat de presença (lastSeen)
      // Chamado a cada 5min enquanto o app está em foreground.
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['lastSeen'])
        && request.resource.data.lastSeen is timestamp;

      // Atualização ADMIN — moderação e ajustes manuais (campo livre).
      // V1: trocar por callable + audit log antes de adicionar segundo admin.
      allow update: if isAdmin();
    }

    // ── Lookup de códigos de afiliado ────────────────────────────────────────
    match /codigos/{codigo} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ── Solicitações de compra de pontos via PIX (DESATIVADO 2026-05) ────────
    // Fluxo descontinuado — usuários agora vão pra waitlist do JUICE airdrop
    // em cnbmobile.com/airdrop. Docs históricos preservados, novas escritas
    // bloqueadas. Ver match /juice_waitlist abaixo.
    match /solicitacoes_compra/{id} {
      allow create: if false;
      allow read, update: if isAdmin();   // dashboard reconcilia compras antigas
      allow delete: if false;
    }

    // ── Solicitações de saque ────────────────────────────────────────────────
    match /saques/{saqueId} {
      allow read: if (request.auth != null && request.auth.uid == resource.data.uid)
                  || isAdmin();
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Fila de eventos de indicação (processada pela Cloud Function) ────────
    match /referral_events/{uid} {
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasAll(['referrerUid'])
        && request.resource.data.referrerUid is string
        && request.resource.data.referrerUid != uid;
      allow read, update, delete: if false;
    }

    // ── Dashboard público ────────────────────────────────────────────────────
    match /stats/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /provas_onchain/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /referrals_onchain/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /provas_sessao/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // ── Dashboard privado (admin) ─────────────────────────────────────────────
    match /resgates_cnb/{doc} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Lista de espera (waitlist) — somente via Cloud Function registrarLead ─
    // Escrita direta bloqueada; rate limiting e validação feitos server-side.
    match /leads/{leadId} {
      allow read, write: if false;
    }

    // ── JUICE Airdrop waitlist — somente via Cloud Function registrarWaitlist ─
    // Escrita direta bloqueada; rate limiting e validação feitos server-side.
    match /juice_waitlist/{leadId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Push tokens — owner escreve, admin lê pra disparar push ──────────────
    match /push_tokens/{uid} {
      allow read: if isAdmin();
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Push jobs (fila de envios criada pelo dashboard) ─────────────────────
    match /push_jobs/{jobId} {
      allow read, create, update: if isAdmin();
      allow delete: if false;
    }

    // ── Banner clicks (telemetria; user logado pode criar, admin lê) ────────
    match /banner_clicks/{clickId} {
      allow create: if request.auth != null
                    && (request.resource.data.uid == null
                        || request.resource.data.uid == request.auth.uid);
      allow read: if isAdmin();
      allow update, delete: if false;
    }

  }
}

function isAdmin() {
  return request.auth != null
    && request.auth.uid == 'X619NYBpp5OqXKTBomuFTISuQGY2'
    && request.auth.token.email_verified == true;
}
