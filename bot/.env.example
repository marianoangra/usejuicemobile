# ─── Telegram ──────────────────────────────────────────────────────
# Como pegar:
# 1. Abre Telegram, busca @BotFather
# 2. Manda /newbot
# 3. Escolhe nome (ex: "Juice Bot") e username (ex: "juice_oficial_bot")
# 4. Cola o token que ele te dá aqui:
TELEGRAM_BOT_TOKEN=

# ─── Anthropic (Claude) ────────────────────────────────────────────
# Como pegar:
# 1. console.anthropic.com → Settings → API Keys → Create Key
# 2. Cola aqui:
ANTHROPIC_API_KEY=

# ─── Firebase Admin (persistência de conversas no dashboard) ──────
# Caminho pra service account key do projeto cnbmobile-2053c.
# Reusa a mesma chave que as Cloud Functions usam em app/sa-key.json.
# Se vazio, o bot roda normal mas NÃO persiste conversas no Firestore.
FIREBASE_SA_PATH=../app/sa-key.json

# ─── Opcional ─────────────────────────────────────────────────────
# Nível de log: info | silent
LOG_LEVEL=info
